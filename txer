<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>手工生小餛飩訂購</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;700&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green-dark:   #0F6E56;
      --green-mid:    #1D9E75;
      --green-light:  #5DCAA5;
      --green-pale:   #E1F5EE;
      --amber-dark:   #633806;
      --amber-mid:    #BA7517;
      --amber-pale:   #FAEEDA;
      --red-pale:     #FCEBEB;
      --red-mid:      #E24B4A;
      --red-dark:     #791F1F;
      --gray-100:     #F5F4F0;
      --gray-200:     #E8E7E2;
      --gray-400:     #B4B2A9;
      --gray-700:     #444441;
      --text-primary: #1a1a18;
      --text-muted:   #5F5E5A;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Noto Sans TC', sans-serif;
      background: #faf9f6;
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* ── Hero ── */
    .hero {
      background: var(--green-dark);
      color: #fff;
      text-align: center;
      padding: 3rem 1.5rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      width: 320px; height: 320px;
      border-radius: 50%;
      background: rgba(93,202,165,0.12);
      top: -80px; right: -60px;
    }
    .hero::after {
      content: '';
      position: absolute;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: rgba(93,202,165,0.08);
      bottom: -40px; left: -40px;
    }
    .hero-icon { font-size: 52px; margin-bottom: 12px; display: block; position: relative; z-index: 1; }
    .hero h1 {
      font-family: 'Noto Serif TC', serif;
      font-size: clamp(24px, 5vw, 32px);
      font-weight: 700;
      letter-spacing: 0.04em;
      position: relative; z-index: 1;
    }
    .hero p {
      font-size: 14px;
      opacity: 0.75;
      margin-top: 8px;
      letter-spacing: 0.06em;
      position: relative; z-index: 1;
    }

    /* ── Container ── */
    .container {
      max-width: 640px;
      margin: 0 auto;
      padding: 2rem 1.25rem 4rem;
    }

    /* ── Section title ── */
    .section-title {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    /* ── Plan cards ── */
    .plans {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 2rem;
    }
    .plan-card {
      background: #fff;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-md);
      padding: 1.25rem 1rem;
      cursor: pointer;
      transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
      position: relative;
      text-align: center;
      user-select: none;
    }
    .plan-card:hover {
      border-color: var(--green-light);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(15,110,86,0.10);
    }
    .plan-card.selected {
      border-color: var(--green-mid);
      border-width: 2px;
      background: var(--green-pale);
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(15,110,86,0.15);
    }
    .plan-badge {
      display: none;
      position: absolute;
      top: -11px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--green-mid);
      color: #fff;
      font-size: 11px;
      font-weight: 500;
      padding: 2px 12px;
      border-radius: 20px;
      white-space: nowrap;
      letter-spacing: 0.04em;
    }
    .plan-card.selected .plan-badge { display: block; }
    .plan-name { font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }
    .plan-count { font-family: 'Noto Serif TC', serif; font-size: 36px; font-weight: 700; color: var(--text-primary); line-height: 1; }
    .plan-unit { font-size: 13px; color: var(--text-muted); margin-top: 2px; }
    .plan-price { font-size: 22px; font-weight: 500; color: var(--green-dark); margin-top: 12px; }
    .plan-per { font-size: 11px; color: var(--gray-400); margin-top: 3px; }

    /* ── Qty ── */
    .qty-block {
      background: #fff;
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-md);
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 1rem;
    }
    .qty-label { font-size: 14px; color: var(--text-muted); flex: 1; }
    .qty-controls { display: flex; align-items: center; gap: 14px; }
    .qty-btn {
      width: 34px; height: 34px;
      border-radius: 50%;
      border: 1.5px solid var(--gray-200);
      background: var(--gray-100);
      cursor: pointer;
      font-size: 20px;
      line-height: 1;
      color: var(--text-primary);
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, border-color 0.15s;
    }
    .qty-btn:hover { background: var(--green-pale); border-color: var(--green-light); }
    .qty-num { font-family: 'Noto Serif TC', serif; font-size: 22px; font-weight: 700; min-width: 28px; text-align: center; }
    .qty-detail { font-size: 13px; color: var(--text-muted); }

    /* ── Total ── */
    .total-block {
      background: var(--green-dark);
      color: #fff;
      border-radius: var(--radius-md);
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }
    .total-label { font-size: 14px; opacity: 0.8; }
    .total-amount { font-family: 'Noto Serif TC', serif; font-size: 28px; font-weight: 700; }

    /* ── Form ── */
    .form-section { margin-bottom: 2rem; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group.full { grid-column: 1 / -1; }
    .form-group label { font-size: 13px; color: var(--text-muted); font-weight: 500; }
    .form-group input,
    .form-group select,
    .form-group textarea {
      font-family: 'Noto Sans TC', sans-serif;
      font-size: 14px;
      padding: 10px 14px;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--gray-200);
      background: #fff;
      color: var(--text-primary);
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: var(--green-mid); }
    .form-group textarea { height: 80px; resize: none; }

    /* ── Error / Success ── */
    .error-msg {
      display: none;
      background: var(--red-pale);
      border: 1px solid #F09595;
      border-radius: var(--radius-sm);
      padding: 0.75rem 1rem;
      font-size: 13px;
      color: var(--red-dark);
      margin-bottom: 1rem;
    }
    .success-block {
      display: none;
      text-align: center;
      padding: 2.5rem 1.5rem;
      background: var(--green-pale);
      border-radius: var(--radius-md);
      border: 1px solid var(--green-light);
    }
    .success-block .icon { font-size: 48px; margin-bottom: 12px; }
    .success-block h2 { font-family: 'Noto Serif TC', serif; font-size: 20px; color: var(--green-dark); }
    .success-block p { font-size: 14px; color: var(--text-muted); margin-top: 8px; }
    .success-block .order-again {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 24px;
      background: var(--green-mid);
      color: #fff;
      border-radius: var(--radius-sm);
      font-size: 14px;
      cursor: pointer;
      border: none;
      font-family: 'Noto Sans TC', sans-serif;
    }

    /* ── Submit ── */
    .submit-btn {
      width: 100%;
      padding: 15px;
      background: var(--green-mid);
      color: #fff;
      border: none;
      border-radius: var(--radius-md);
      font-size: 16px;
      font-weight: 500;
      font-family: 'Noto Sans TC', sans-serif;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: background 0.2s, transform 0.15s;
    }
    .submit-btn:hover:not(:disabled) { background: var(--green-dark); transform: translateY(-1px); }
    .submit-btn:disabled { background: var(--gray-400); cursor: not-allowed; transform: none; }

    /* ── Notice ── */
    .notice {
      background: var(--amber-pale);
      border: 1px solid #FAC775;
      border-radius: var(--radius-sm);
      padding: 0.75rem 1rem;
      font-size: 12px;
      color: var(--amber-dark);
      margin-bottom: 1.5rem;
      line-height: 1.7;
    }
    .notice strong { font-weight: 500; }

    /* ── Footer ── */
    footer {
      text-align: center;
      font-size: 12px;
      color: var(--gray-400);
      padding: 1.5rem 1rem;
      border-top: 1px solid var(--gray-200);
    }

    @media (max-width: 480px) {
      .plans { grid-template-columns: 1fr; gap: 12px; }
      .form-grid { grid-template-columns: 1fr; }
      .form-group.full { grid-column: 1; }
    }
  </style>
</head>
<body>

<div class="hero">
  <span class="hero-icon">🥟</span>
  <h1>手工生小餛飩</h1>
  <p>新鮮現做・皮薄餡嫩・限量販售</p>
</div>

<div class="container">

  <!-- ⚠️ 部署前請先移除此區塊 -->
  <div class="notice" id="setup-notice">
    <strong>⚙️ 設定提醒（上線前請移除此訊息）：</strong><br>
    請將 <code>SCRIPT_URL</code> 換成你的 Google Apps Script 網址，詳見 README。
  </div>

  <div class="section-title">選擇方案</div>
  <div class="plans" id="plans">
    <div class="plan-card" data-idx="0" onclick="selectPlan(0)">
      <div class="plan-badge">最划算</div>
      <div class="plan-name">小份</div>
      <div class="plan-count">30</div>
      <div class="plan-unit">顆</div>
      <div class="plan-price">$135</div>
      <div class="plan-per">每顆 $4.5</div>
    </div>
    <div class="plan-card selected" data-idx="1" onclick="selectPlan(1)">
      <div class="plan-badge">最划算</div>
      <div class="plan-name">中份</div>
      <div class="plan-count">60</div>
      <div class="plan-unit">顆</div>
      <div class="plan-price">$250</div>
      <div class="plan-per">每顆 $4.2</div>
    </div>
    <div class="plan-card" data-idx="2" onclick="selectPlan(2)">
      <div class="plan-badge">最划算</div>
      <div class="plan-name">大份</div>
      <div class="plan-count">90</div>
      <div class="plan-unit">顆</div>
      <div class="plan-price">$350</div>
      <div class="plan-per">每顆 $3.9</div>
    </div>
  </div>

  <div class="section-title">訂購數量</div>
  <div class="qty-block">
    <div class="qty-label">份數（每份獨立包裝）</div>
    <div class="qty-controls">
      <button class="qty-btn" onclick="changeQty(-1)" aria-label="減少">−</button>
      <div class="qty-num" id="qty-display">1</div>
      <button class="qty-btn" onclick="changeQty(1)" aria-label="增加">+</button>
    </div>
    <div class="qty-detail" id="qty-detail">60顆 × 1份</div>
  </div>

  <div class="total-block">
    <div class="total-label">合計金額</div>
    <div class="total-amount" id="total">$250</div>
  </div>

  <div class="section-title">填寫資料</div>
  <div class="form-section" id="form-section">
    <div class="form-grid">
      <div class="form-group">
        <label for="name">姓名 *</label>
        <input type="text" id="name" placeholder="王小明" autocomplete="name" />
      </div>
      <div class="form-group">
        <label for="phone">電話 *</label>
        <input type="tel" id="phone" placeholder="0912-345-678" autocomplete="tel" />
      </div>
      <div class="form-group full">
        <label for="pickup">取貨方式 *</label>
        <select id="pickup">
          <option value="">請選擇</option>
          <option value="自取">自取</option>
          <option value="宅配">宅配（另計運費，事後告知）</option>
        </select>
      </div>
      <div class="form-group full">
        <label for="note">備註</label>
        <textarea id="note" placeholder="希望取貨時間、口味偏好…"></textarea>
      </div>
    </div>
  </div>

  <div class="error-msg" id="error-msg">請填寫所有必填欄位（姓名、電話、取貨方式）</div>

  <button class="submit-btn" id="submit-btn" onclick="submitOrder()">確認送出訂單</button>

  <div class="success-block" id="success-block">
    <div class="icon">✅</div>
    <h2>訂單已收到！</h2>
    <p>感謝您的訂購，我們將盡快與您電話確認<br>取貨時間與付款方式</p>
    <button class="order-again" onclick="resetForm()">繼續訂購</button>
  </div>

</div>

<footer>手工生小餛飩 · 新鮮現做</footer>

<script>
  // ✅ 請將此換成你的 Google Apps Script 部署網址
  const SCRIPT_URL = "YOUR_GOOGLE_APPS_SCRIPT_URL_HERE";

  const plans = [
    { name: "小份", count: 30, price: 135, per: "4.5" },
    { name: "中份", count: 60, price: 250, per: "4.2" },
    { name: "大份", count: 90, price: 350, per: "3.9" }
  ];

  let selectedPlan = 1;
  let qty = 1;

  // 初始化：只有被選中的 card 才顯示 badge
  function initBadges() {
    // 小份不是最划算，中份才是
    const labels = ["", "最划算", ""];
    document.querySelectorAll(".plan-card").forEach((card, i) => {
      card.querySelector(".plan-badge").textContent = labels[i];
    });
  }
  initBadges();

  function selectPlan(idx) {
    selectedPlan = idx;
    document.querySelectorAll(".plan-card").forEach((c, i) => {
      c.classList.toggle("selected", i === idx);
    });
    updateTotal();
  }

  function changeQty(delta) {
    qty = Math.max(1, Math.min(20, qty + delta));
    document.getElementById("qty-display").textContent = qty;
    updateTotal();
  }

  function updateTotal() {
    const p = plans[selectedPlan];
    document.getElementById("qty-detail").textContent = p.count + "顆 × " + qty + "份";
    document.getElementById("total").textContent = "$" + (p.price * qty);
  }

  function submitOrder() {
    const name   = document.getElementById("name").value.trim();
    const phone  = document.getElementById("phone").value.trim();
    const pickup = document.getElementById("pickup").value;
    const note   = document.getElementById("note").value.trim();
    const errEl  = document.getElementById("error-msg");

    if (!name || !phone || !pickup) {
      errEl.style.display = "block";
      errEl.scrollIntoView({ behavior: "smooth", block: "center" });
      return;
    }
    errEl.style.display = "none";

    const btn = document.getElementById("submit-btn");
    btn.disabled = true;
    btn.textContent = "送出中…";

    const p = plans[selectedPlan];
    const now = new Date();
    const ts = now.toLocaleString("zh-TW", { timeZone: "Asia/Taipei" });

    const payload = {
      timestamp: ts,
      name,
      phone,
      plan: p.name,
      count: p.count + "顆",
      qty,
      unitPrice: p.price,
      totalPrice: p.price * qty,
      pickup,
      note
    };

    fetch(SCRIPT_URL, {
      method:  "POST",
      mode:    "no-cors",
      headers: { "Content-Type": "application/json" },
      body:    JSON.stringify(payload)
    })
    .then(() => {
      document.getElementById("form-section").style.display = "none";
      btn.style.display = "none";
      document.getElementById("success-block").style.display = "block";
      document.getElementById("success-block").scrollIntoView({ behavior: "smooth" });
    })
    .catch(() => {
      errEl.textContent = "⚠️ 送出失敗，請檢查網路或稍後再試";
      errEl.style.display = "block";
      btn.disabled = false;
      btn.textContent = "確認送出訂單";
    });
  }

  function resetForm() {
    document.getElementById("name").value = "";
    document.getElementById("phone").value = "";
    document.getElementById("pickup").value = "";
    document.getElementById("note").value = "";
    document.getElementById("form-section").style.display = "block";
    document.getElementById("submit-btn").style.display = "block";
    document.getElementById("submit-btn").disabled = false;
    document.getElementById("submit-btn").textContent = "確認送出訂單";
    document.getElementById("success-block").style.display = "none";
    document.getElementById("error-msg").style.display = "none";
    qty = 1;
    selectPlan(1);
    changeQty(0);
    window.scrollTo({ top: 0, behavior: "smooth" });
  }
</script>
</body>
</html>
